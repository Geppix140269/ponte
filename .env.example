# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Same project URL, without the NEXT_PUBLIC_ prefix. Only needed outside Next,
# where that prefix means nothing: the scheduled sanctions refresh reads this
# first and falls back to NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=

# ----- Stripe -----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- Google OAuth -----
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ----- Resend (email) -----
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@ponte.trade

# ----- Admin -----
ADMIN_ALERT_EMAIL=g.funaro@1402celsius.com

# ----- Ops alerts (Telegram) -----
# Brokerage submissions ping this chat. Setup is in lib/telegram.ts and
# docs/TELEGRAM-OPS-SETUP.md.
#
# BOTH ARE OPTIONAL AND FAIL SILENTLY. If either is missing the wrapper is a
# no-op: no error, no log, no alert. That makes this the easiest pair to lose
# in a host migration and the hardest to notice, because the only symptom is
# an ops message that never arrives. If it is set on the old host, set it on
# the new one, then post a real submission and confirm the ping.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPS_CHAT_ID=

# ----- Feature flags -----
# Below this many approved listings the marketplace hides the board rather
# than showing an empty one. Default 3.
BOARD_MIN_LISTINGS=

# Launch switch for the public Desk Radar section. "1" lights it, anything
# else holds it back. Not a legal gate: the redaction rules in
# lib/board/live-deals.ts apply either way. Held back until the CSV import
# has run.
DESK_RADAR_PUBLIC=

# ----- Brokerage -----
# Where Deal Desk submissions and Deal Sheet access requests are sent.
# Set up a mailbox or forward for deals@ponte.trade, or point this at a
# personal address until that exists.
DEALS_TO_EMAIL=deals@ponte.trade

# ----- App -----
NEXT_PUBLIC_APP_URL=https://ponte.trade

# ----- AI vetting co-pilot -----
ANTHROPIC_API_KEY=
# AI_VET_MODEL=claude-sonnet-4-6

# ----- Ponte AI (freemium) -----
# Stripe Payment Link for the Ponte AI subscription ($19/month).
# Create it in the Stripe dashboard, paste the URL here.
NEXT_PUBLIC_AI_PAYMENT_LINK=

# ----- Verification: company registries -----
# UK Companies House REST API. FREE, but Giuseppe must register for a key:
# https://developer.company-information.service.gov.uk/  (create an
# application, then a "REST API" key). Without it, UK lookups are skipped and
# every UK case routes to manual review.
COMPANIES_HOUSE_API_KEY=

# OpenCorporates, for the 140+ jurisdictions outside the UK. OPTIONAL.
# Free tier requires attribution, paid tiers are metered:
# https://opencorporates.com/api_accounts/new
# If this is empty the code does NOT pretend the registry was clean: the
# lookup returns "registry not checked" and the case goes to human review.
OPENCORPORATES_API_KEY=

# VIES (EU VAT validation) and GLEIF (LEI lookup) need no key and no account.

# ----- Third party datasources -----
# Identity sent in the outbound User-Agent on every call to a public data
# provider. Several of them, OSM especially, ban by User-Agent, and a ban is
# silent. Keep this a real reachable address.
DATASOURCE_CONTACT_EMAIL=ops@ponte.trade

# FX. The two primary providers, ECB via Frankfurter and the ExchangeRate-API
# open endpoint, need NO key. This is an optional third opinion only: without
# it the median is taken across two providers instead of three.
FREECURRENCYAPI_KEY=

# Tariff. WTO Timeseries corroborates WITS. Free, but needs an account at
# apiportal.wto.org. WITS, USITC, the UK trade tariff and CBP need no key.
WTO_API_KEY=

# Tenders. US federal opportunities. Free key from sam.gov. Every other
# procurement source in the registry is open.
SAM_GOV_API_KEY=

# OpenSanctions. FREE TO SELF HOST, NOT FREE TO USE AS AN API IN PRODUCTION:
# the hosted API needs a commercial licence. Left off until that is confirmed
# in writing. Live sanctions screening is NOT this: it lives in the
# verification module and uses the published OFAC, EU, UN and UK OFSI lists.
DATA_OPENSANCTIONS_ENABLED=false
OPENSANCTIONS_API_KEY=

# Logistics and risk, all freemium free tiers.
FIRMS_MAP_KEY=
AISSTREAM_API_KEY=
ECONDB_API_KEY=
GFW_API_TOKEN=
OPENAQ_API_KEY=

# Map tiles. Everything except Copernicus is keyless and client safe.
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# ----- Verification: sanctions screening -----
# OFAC, EU, UN and UK OFSI lists are all published free and need no key.
#
# The scheduled rebuild runs in GitHub Actions, not in a function, so it needs
# no secret: it holds the service role key directly. This secret guards the
# manual trigger at POST /api/cron/sanctions-refresh, which is kept for an
# operator with a shell but no GitHub access. Generate any long random string.
# Note that route will return 504 on a full refresh, by design of the host, not
# by design of the code. See docs/platform/RUNBOOK.md.
SANCTIONS_REFRESH_SECRET=

# ----- Local tooling only. NEVER set these on the host. -----
# Nothing the site serves reads these. They are for scripts run from a
# developer machine, and each one is a master credential: DATABASE_URL is a
# direct Postgres connection, and the access token is account level rather
# than project level, so it reaches every Supabase project on the account.
#
# Putting them in the hosting dashboard would hand that reach to every
# function the site runs, for no gain, and would widen the blast radius of a
# single leaked deploy log. Keep them in .env.local.
#
# scripts/apply-migration.mjs
DATABASE_URL=
# scripts/db-query.mjs
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
