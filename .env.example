# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Stripe -----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- Google OAuth -----
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ----- Resend (email) -----
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@ponte.trade

# ----- Admin -----
ADMIN_ALERT_EMAIL=g.funaro@1402celsius.com

# ----- Brokerage -----
# Where Deal Desk submissions and Deal Sheet access requests are sent.
# Set up a mailbox or forward for deals@ponte.trade, or point this at a
# personal address until that exists.
DEALS_TO_EMAIL=deals@ponte.trade

# ----- App -----
NEXT_PUBLIC_APP_URL=https://ponte.trade

# ----- AI vetting co-pilot -----
ANTHROPIC_API_KEY=
# AI_VET_MODEL=claude-sonnet-4-6

# ----- Ponte AI (freemium) -----
# Stripe Payment Link for the Ponte AI subscription ($19/month).
# Create it in the Stripe dashboard, paste the URL here.
NEXT_PUBLIC_AI_PAYMENT_LINK=

# ----- Verification: company registries -----
# UK Companies House REST API. FREE, but Giuseppe must register for a key:
# https://developer.company-information.service.gov.uk/  (create an
# application, then a "REST API" key). Without it, UK lookups are skipped and
# every UK case routes to manual review.
COMPANIES_HOUSE_API_KEY=

# OpenCorporates, for the 140+ jurisdictions outside the UK. OPTIONAL.
# Free tier requires attribution, paid tiers are metered:
# https://opencorporates.com/api_accounts/new
# If this is empty the code does NOT pretend the registry was clean: the
# lookup returns "registry not checked" and the case goes to human review.
OPENCORPORATES_API_KEY=

# VIES (EU VAT validation) and GLEIF (LEI lookup) need no key and no account.

# ----- Verification: sanctions screening -----
# OFAC, EU, UN and UK OFSI lists are all published free and need no key.
# Secret shared with the scheduled refresh function, so only the cron can
# trigger a rebuild of the sanctions tables. Generate any long random string.
SANCTIONS_REFRESH_SECRET=
